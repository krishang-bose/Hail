# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here    # keep secret — never commit

# ── AI Providers ─────────────────────────────────────────────────────────────
# Add at least one. App tries each in order, falls back automatically.
# Recommended: add all — they use different rate-limit buckets.

# Gemini 2.0 Flash Lite — free 1,500 req/day → https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Llama 3.3 70B — free 14,400 req/day → https://console.groq.com
GROQ_API_KEY=

# Cerebras Llama 3.1 8B — world's fastest (2100 tok/s), free → https://cloud.cerebras.ai
# Used for outreach generation (8B is sufficient for short structured text)
CEREBRAS_API_KEY=

# Together AI — $1 free credit → https://api.together.ai
TOGETHER_API_KEY=

# Cohere command-r-plus — free 1,000 req/month → https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Mistral — optional fallback → https://console.mistral.ai
MISTRAL_API_KEY=

# ── Real Data APIs ────────────────────────────────────────────────────────────
# All optional — app degrades gracefully without them, but data quality improves greatly.

# Hunter.io — real employee emails + people at a domain
# 25 free domain searches/month → https://hunter.io/api-keys
HUNTER_API_KEY=

# GitHub — person's repos, languages, open-source projects (outreach context)
# Free: 60 req/hr without token, 5000 req/hr with token
# Create at: https://github.com/settings/tokens → NO scopes needed (public data only)
GITHUB_TOKEN=

# Product Hunt — company's product launches (unique outreach hook: "I saw your launch of X")
# Get your developer_token (no OAuth needed) at: https://www.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=

# Firecrawl — scrapes company homepages for og:description / meta description
# (the company's own words, used for social sharing — best description source)
# Get a free key at: https://firecrawl.dev
FIRECRAWL_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID → Web application
# Authorized redirect URI: https://your-domain.com/api/auth/callback/google
# Local:                   http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=your_nextauth_secret

# Only needed for local dev (Vercel sets NEXTAUTH_URL automatically)
NEXTAUTH_URL=http://localhost:3000

